        </div>
      </div>

      <div className="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-16">
        <div className="grid lg:grid-cols-2 gap-12 items-center">
          {/* Left Side - Info Card */}
          <div className="order-2 lg:order-1">
            <div className="bg-[#001C54]/90 backdrop-blur-sm text-white p-8 rounded-lg max-w-xl">
              <p className="text-lg mb-6">
                For 35 years, JAIN College has been a{" "}
                <span className="font-bold">HALLMARK OF TRUST</span> in
                Pre-University education, consistently delivering outstanding
                academic performance.
              </p>

              <h3 className="font-bold text-xl mb-4">
                At JAIN College, you will:
              </h3>

              <ul className="space-y-3 text-sm leading-relaxed">
                <li className="flex items-start gap-2">
                  <span className="text-[#F8C300] mt-1">→</span>
                  <span>
                    Achieve success in Pre-University board examinations through
                    a proven, meticulously structured education model.
                  </span>
                </li>
                <li className="flex items-start gap-2">
                  <span className="text-[#F8C300] mt-1">→</span>
                  <span>
                    Gain valuable career insights by engaging with professionals
                    from diverse fields.
                  </span>
                </li>
                <li className="flex items-start gap-2">
                  <span className="text-[#F8C300] mt-1">→</span>
                  <span>
                    Strengthen leadership abilities through active participation
                    in a variety of student-driven initiatives.
                  </span>
                </li>
                <li className="flex items-start gap-2">
                  <span className="text-[#F8C300] mt-1">→</span>
                  <span>
                    Explore numerous extracurricular opportunities that
                    contribute to a dynamic and enriching student life.
                  </span>
                </li>
                <li className="flex items-start gap-2">
                  <span className="text-[#F8C300] mt-1">→</span>
                  <span>
                    Become part of a distinguished community of scholars,
                    innovatorsand leaders, shaping the future with knowledge
                    and vision.
                  </span>
                </li>
              </ul>
            </div>
          </div>

          {/* Right Side - Login Form */}
          <div className="order-1 lg:order-2 flex justify-center lg:justify-end">
            <div className="bg-white rounded-xl shadow-2xl p-8 w-full max-w-md relative ml-0 lg:ml-36">
              {/* Animated Mascot - positioned to the left */}
              <FormMascot focusedField={focusedField} userName={userName} />
              <PrivacyMascot isVisible={isPasswordFocused} />

              {/* Logo */}
              <div className="flex items-center justify-center gap-3 mb-6">
                <div className="w-10 h-10 bg-[#001C54] rounded-full flex items-center justify-center">
                  <span className="text-white font-bold text-sm">JGI</span>
                </div>
                <span className="text-[#001C54] font-bold text-xl">
                  JAIN COLLEGE
                </span>
              </div>

              {/* Form Card */}
              <div className="border border-gray-200 rounded-lg p-6 relative">
                <h2 className="text-center text-gray-800 mb-6">
                  I PUC Admissions - Online Registration
                  <br />
                  Form <span className="font-bold">2026-27</span>
                </h2>

                {/* Tab Buttons */}
                <div className="flex gap-4 mb-6">
                  <button
                    onClick={() => setActiveTab("login")}
                    className={`flex-1 py-3 rounded-full font-semibold transition-all ${
                      activeTab === "login"
