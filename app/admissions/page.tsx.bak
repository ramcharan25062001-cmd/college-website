                        <option value="ib">IB</option>
                        <option value="other">Other</option>
                      </select>
                    </div>
                    <div>
                      <input
                        type="text"
                        placeholder="STUDENT NAME"
                        onFocus={() => setFocusedField("name")}
                        onChange={(e) => setUserName(e.target.value)}
                        className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-[#001C54] text-sm transition-all focus:ring-2 focus:ring-[#001C54]/20"
                      />
                    </div>
