                      />
                    </div>
                    <div>
                      <input
                        type="tel"
                        placeholder="MOBILE NUMBER"
                        onFocus={() => setFocusedField("mobile")}
                        className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-[#001C54] text-sm transition-all focus:ring-2 focus:ring-[#001C54]/20"
                      />
                    </div>
                    <div>
                      <input
                        type="password"
                        placeholder="PASSWORD"
                        onFocus={() => setFocusedField("password")}
                        className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-[#001C54] text-sm transition-all focus:ring-2 focus:ring-[#001C54]/20"
                      />
                    </div>
                    <div>
                      <input
