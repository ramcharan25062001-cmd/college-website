/*
"use client";

import { useState, useEffect } from "react";
import Header from "../components/Header";
import Footer from "../components/Footer";
import Link from "next/link";

// Animated Mascot Component
const FormMascot = ({
  focusedField,
  userName,
}: {
  focusedField: string | null;
  userName: string;
}) => {
  const [isVisible, setIsVisible] = useState(false);
  const [isWaving, setIsWaving] = useState(false);

  useEffect(() => {
    if (
      focusedField &&
      focusedField !== "password" &&
      focusedField !== "confirmPassword" &&
      focusedField !== "loginPassword"
    ) {
      setIsVisible(true);
      setIsWaving(true);
      const timer = setTimeout(() => setIsWaving(false), 1000);
      return () => clearTimeout(timer);
    } else if (
      focusedField === "password" ||
      focusedField === "confirmPassword" ||
      focusedField === "loginPassword"
    ) {
      // Fade out for privacy
      setIsVisible(false);
    }
  }, [focusedField]);

  const getMessage = () => {
    if (
      focusedField === "password" ||
      focusedField === "confirmPassword" ||
      focusedField === "loginPassword"
    ) {
      return null; // Hidden for privacy
    }
    if (focusedField === "name" && userName) {
      return `Hello, ${userName}! 👋`;
    }
    if (focusedField === "name") {
      return "What's your name? 😊";
    }
    if (focusedField === "email") {
      return userName ? `${userName}, your email! 📧` : "Your email please! 📧";
    }
    if (focusedField === "mobile") {
      return userName
        ? `Phone number, ${userName}! 📱`
        : "Phone number please! 📱";
    }
    if (focusedField === "board") {
      return "Your board? 🎓";
    }
    if (focusedField === "loginEmail") {
      return "Welcome back! 🔑";
    }
    return "Welcome! 🎉";
  };

  const message = getMessage();

  if (!message) {
    return null;
  }

  return (
    <div
      className={`absolute -left-32 top-1/2 -translate-y-1/2 transition-all duration-500 hidden lg:block ${
        isVisible ? "opacity-100 translate-x-0" : "opacity-0 -translate-x-4"
      }`}
    >
      <div className="flex flex-col items-center">
        {/* Mascot Face */}
        <div
          className={`w-16 h-16 bg-[#F8C300] rounded-full flex items-center justify-center shadow-lg relative ${
            isWaving ? "animate-bounce" : ""
          }`}
        >
          {/* Eyes */}
          <div className="absolute top-4 left-3 w-3 h-3 bg-[#001C54] rounded-full">
            <div className="absolute top-0.5 left-0.5 w-1.5 h-1.5 bg-white rounded-full"></div>
          </div>
          <div className="absolute top-4 right-3 w-3 h-3 bg-[#001C54] rounded-full">
            <div className="absolute top-0.5 left-0.5 w-1.5 h-1.5 bg-white rounded-full"></div>
          </div>

          {/* Smile */}
          <div className="absolute bottom-3 left-1/2 -translate-x-1/2 w-8 h-4 border-b-4 border-[#001C54] rounded-b-full"></div>

          {/* Waving Hand */}
          <div
            className={`absolute -right-3 -top-1 text-xl transition-transform ${
              isWaving ? "animate-wave" : ""
            }`}
          >
            👋
          </div>

          {/* Graduation Cap */}
          <div className="absolute -top-3 left-1/2 -translate-x-1/2">
            <div className="w-10 h-2 bg-[#001C54] rounded-sm"></div>
            <div className="w-6 h-4 bg-[#001C54] mx-auto -mt-1 rounded-sm"></div>
            <div className="absolute -right-2 -top-1 w-4 h-0.5 bg-[#001C54] rotate-45 origin-left">
              <div className="absolute right-0 -top-1 w-2 h-2 bg-[#F8C300] rounded-full"></div>
            </div>
          </div>
        </div>

        {/* Speech Bubble - pointing right */}
        <div className="relative bg-[#001C54] text-white px-3 py-2 rounded-xl text-xs font-medium shadow-lg mt-2 max-w-24 text-center">
          {message}
          {/* Bubble Tail pointing up */}
          <div className="absolute -top-2 left-1/2 -translate-x-1/2 w-0 h-0 border-l-6 border-r-6 border-b-8 border-transparent border-b-[#001C54]"></div>
        </div>
      </div>
    </div>
  );
};

// Privacy Mascot (shows when password is focused)
const PrivacyMascot = ({ isVisible }: { isVisible: boolean }) => {
  return (
    <div
      className={`absolute -left-32 top-1/2 -translate-y-1/2 transition-all duration-500 hidden lg:block ${
        isVisible
          ? "opacity-100 translate-x-0"
          : "opacity-0 -translate-x-4 pointer-events-none"
      }`}
    >
      <div className="flex flex-col items-center">
        {/* Mascot Face with Covered Eyes */}
        <div className="w-16 h-16 bg-[#F8C300] rounded-full flex items-center justify-center shadow-lg relative">
          {/* Hands Covering Eyes */}
          <div className="absolute top-3 left-2 text-lg">🙈</div>

          {/* Smile */}
          <div className="absolute bottom-3 left-1/2 -translate-x-1/2 w-6 h-3 border-b-2 border-[#001C54] rounded-b-full"></div>

          {/* Graduation Cap */}
          <div className="absolute -top-3 left-1/2 -translate-x-1/2">
            <div className="w-10 h-2 bg-[#001C54] rounded-sm"></div>
            <div className="w-6 h-4 bg-[#001C54] mx-auto -mt-1 rounded-sm"></div>
          </div>
        </div>

        {/* Speech Bubble */}
        <div className="relative bg-gray-700 text-white px-3 py-2 rounded-xl text-xs font-medium shadow-lg mt-2 max-w-24 text-center">
          🔒 Shh! Privacy...
          {/* Bubble Tail pointing up */}
          <div className="absolute -top-2 left-1/2 -translate-x-1/2 w-0 h-0 border-l-6 border-r-6 border-b-8 border-transparent border-b-gray-700"></div>
        </div>
      </div>
    </div>
  );
};

// Hero Section with Login Form
const AdmissionsHero = () => {
  const [activeTab, setActiveTab] = useState<"login" | "registration">("login");
  const [focusedField, setFocusedField] = useState<string | null>(null);
  const [userName, setUserName] = useState("");

  const isPasswordFocused =
    focusedField === "password" ||
    focusedField === "confirmPassword" ||
    focusedField === "loginPassword";

  return (
    <section className="relative min-h-[90vh] flex items-center">
      {/* Background Image */}
      <div className="absolute inset-0 z-0">
