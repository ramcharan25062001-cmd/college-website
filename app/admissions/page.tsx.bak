                    >
                      Register
                    </button>
                  </form>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  );
};

// Achievements Section with State Toppers
const AchievementsSection = () => {
  const [currentSlide, setCurrentSlide] = useState(1);

  const toppers = [
    {
      name: "Avani Prasad",
      score: "98.33",
      stream: "ABEM",
      campus: "VV Puram",
    },
    {
      name: "Sneha Reddy",
      score: "98.17",
      stream: "PCMB",
      campus: "Jayanagar",
    },
    {
      name: "Rahul Kumar",
      score: "97.83",
      stream: "PCMC",
      campus: "Vasavi Road",
    },
  ];

  const nextSlide = () => {
    setCurrentSlide((prev) => (prev + 1) % toppers.length);
  };

  const prevSlide = () => {
    setCurrentSlide((prev) => (prev - 1 + toppers.length) % toppers.length);
  };

  return (
    <section className="py-16 bg-white">
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div className="grid lg:grid-cols-2 gap-12 items-center">
          {/* Left Side - Achievement Info */}
          <div className="border-r-0 lg:border-r-2 border-gray-200 pr-0 lg:pr-12">
            <span className="inline-block border border-[#001C54] text-[#001C54] px-4 py-1 rounded-full text-sm font-medium mb-4">
              Achievements
            </span>
            <h2 className="text-3xl md:text-4xl font-bold text-[#001C54] mb-6">
              2024-2025 PUC BOARD STATE TOPPERS
            </h2>
            <p className="text-gray-600 mb-8 leading-relaxed">
              At JAIN College, we believe in nurturing brilliance. Our students
              have again made us proud by securing top ranks in the Karnataka
              2nd PUC Board Exams.
            </p>
            <Link
              href="/results"
              className="inline-block bg-[#001C54] text-white px-8 py-3 rounded-full font-semibold hover:bg-[#16336e] transition-colors"
            >
              View our results
            </Link>
          </div>

          {/* Right Side - Topper Carousel */}
          <div className="relative">
            {/* Quote Icon */}
            <div className="text-[#001C54] text-6xl font-serif mb-4">"</div>

            {/* Navigation Arrows */}
            <div className="absolute top-0 right-0 flex gap-2">
              <button
                onClick={prevSlide}
                className="w-10 h-10 rounded-full border-2 border-[#001C54] text-[#001C54] flex items-center justify-center hover:bg-[#001C54] hover:text-white transition-colors"
              >
                <svg
                  className="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    strokeLinecap="round"
                    strokeLinejoin="round"
                    strokeWidth={2}
                    d="M15 19l-7-7 7-7"
                  />
                </svg>
              </button>
              <button
                onClick={nextSlide}
                className="w-10 h-10 rounded-full border-2 border-[#001C54] text-[#001C54] flex items-center justify-center hover:bg-[#001C54] hover:text-white transition-colors"
              >
                <svg
                  className="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    strokeLinecap="round"
                    strokeLinejoin="round"
                    strokeWidth={2}
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </button>
            </div>

            {/* Topper Card */}
            <div className="mt-4">
              <h3 className="text-2xl font-bold text-gray-800 mb-4">
                {toppers[currentSlide].name}
              </h3>
              <div className="flex items-center gap-4">
                {/* Profile Image Placeholder */}
                <div className="w-16 h-16 rounded-full bg-gray-200 flex items-center justify-center overflow-hidden">
                  <svg
                    className="w-10 h-10 text-gray-400"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fillRule="evenodd"
                      d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                      clipRule="evenodd"
                    />
                  </svg>
                </div>
                <div>
                  <p className="text-[#001C54] font-bold">
                    {toppers[currentSlide].score} |{" "}
                    {toppers[currentSlide].stream}
                  </p>
                  <p className="text-gray-500 text-sm">
                    {toppers[currentSlide].campus}
                  </p>
                </div>
              </div>

              {/* Dots Indicator */}
              <div className="flex gap-2 mt-6">
                {toppers.map((_, index) => (
                  <button
                    key={index}
                    onClick={() => setCurrentSlide(index)}
                    className={`w-3 h-3 rounded-full transition-colors ${
                      index === currentSlide
                        ? "bg-[#001C54]"
                        : "border border-[#001C54]"
                    }`}
                  />
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Bottom Banner */}
      <div className="bg-[#001C54] mt-16 py-4">
        <div className="max-w-7xl mx-auto px-4 text-center">
          <p className="text-white">
            Visit{" "}
            <span className="font-bold text-[#F8C300]">jaincollege.ac.in</span>{" "}
            to explore JAIN College's academic programmes, student lifeand the
            opportunities that await you.
          </p>
        </div>
      </div>
    </section>
  );
};

